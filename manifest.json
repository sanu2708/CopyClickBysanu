{
  "manifest_version": 3,
  "name": "Copyclick by Sanu Singh",
  "version": "1.0",
  "description": "The ultimate productivity companion for instant text and image retrieval by Sanu Singh",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon.svg"
  },
  "permissions": [
    "clipboardWrite",
    "storage"
  ],
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  }
}
